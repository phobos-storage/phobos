prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: @PACKAGE@
Description: Parallel Heterogeneous OBject-Oriented Storage
Version: @VERSION@
Requires: glib-2.0, gthread-2.0, jansson >= 2.5, libattr
Requires.private: libpq >= 9.4, libprotobuf-c
Libs: -L${libdir} -lphobos_store -lphobos_admin \
      -L${libdir}/phobos -Wl,-rpath,${libdir}/phobos -lpho_core
Libs.private: -lcrypto
Cflags: -I${includedir}
